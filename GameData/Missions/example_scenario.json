{
  "id": "example_scenario",
  "displayName": "First Contact",
  "description": "A training scenario: move your fleet to the waypoint and neutralize enemy scouts.",
  "map": "sector_alpha",
  "briefing": {
    "text": "Commander, our sensors have detected enemy scout activity in Sector Alpha. Move your fleet to the marked waypoint and eliminate any hostiles you encounter. Reinforcements will arrive shortly after engagement.",
    "objectivesPreview": [
      "Move fleet to the waypoint",
      "Destroy all enemy scouts"
    ]
  },
  "startConditions": {
    "playerSpawn": [3, 3],
    "startingUnits": ["scout_light", "scout_light", "cruiser_heavy"],
    "startingResources": { "energy": 500, "minerals": 300, "data": 100, "crew": 10 }
  },
  "objectives": {
    "primary": [
      {
        "id": "reach_waypoint",
        "type": "reach_area",
        "position": [32, 32],
        "radius": 5.0,
        "description": "Move any ship to the waypoint at sector center"
      },
      {
        "id": "destroy_scouts",
        "type": "destroy_target",
        "target": "enemy_scouts",
        "description": "Destroy all enemy scout ships"
      }
    ],
    "secondary": [
      {
        "id": "no_losses",
        "type": "condition",
        "condition": "player_units_alive >= 3",
        "description": "Complete the mission without losing any ships"
      }
    ]
  },
  "triggers": [
    {
      "id": "reinforcements",
      "condition": {
        "type": "timer",
        "seconds": 60
      },
      "actions": [
        { "type": "spawn_units", "units": ["scout_light"], "position": [5, 5] },
        { "type": "dialog", "speaker": "Fleet Command", "text": "Reinforcements have arrived, Commander." }
      ],
      "oneShot": true
    },
    {
      "id": "enemy_patrol",
      "condition": {
        "type": "area_enter",
        "position": [30, 30],
        "radius": 10.0
      },
      "actions": [
        { "type": "spawn_units", "units": ["scout_light", "scout_light"], "position": [35, 35] },
        { "type": "dialog", "speaker": "Sensors", "text": "Enemy contacts detected! Engaging!" }
      ],
      "oneShot": true
    }
  ],
  "victory": { "type": "all_primary_complete" },
  "defeat": { "type": "hero_destroyed" },
  "rewards": {
    "resources": { "energy": 200, "minerals": 150, "data": 50, "crew": 2 },
    "xp": 100,
    "unlocks": ["cruiser_heavy"]
  }
}
