# default_ship.obj — simple diamond-shaped placeholder spaceship
# Used when a ship mesh key cannot be resolved.
# 6 vertices forming a top-down arrowhead silhouette with minimal depth.

# Vertices
v  0.0  0.1  0.0
v  0.5  0.0 -0.3
v  0.5  0.0  0.3
v -0.5  0.0 -0.2
v -0.5  0.0  0.2
v  0.0 -0.1  0.0

# Normals
vn  0.0  1.0  0.0
vn  0.0 -1.0  0.0

# Top faces (bow-forward arrowhead)
f 1//1 3//1 2//1
f 1//1 4//1 3//1
f 3//1 4//1 5//1
f 4//1 5//1 6//1

# Bottom faces (mirror)
f 1//2 2//2 3//2
f 1//2 3//2 4//2
f 3//2 5//2 4//2
f 4//2 6//2 5//2
