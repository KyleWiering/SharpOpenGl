# default_base.obj — simple octagonal platform for base/structure placeholder.
# Used when a base mesh key cannot be resolved.

# Vertices — top ring (y = 0.05)
v  0.5  0.05  0.0
v  0.35 0.05  0.35
v  0.0  0.05  0.5
v -0.35 0.05  0.35
v -0.5  0.05  0.0
v -0.35 0.05 -0.35
v  0.0  0.05 -0.5
v  0.35 0.05 -0.35

# Vertices — bottom ring (y = -0.05)
v  0.5  -0.05  0.0
v  0.35 -0.05  0.35
v  0.0  -0.05  0.5
v -0.35 -0.05  0.35
v -0.5  -0.05  0.0
v -0.35 -0.05 -0.35
v  0.0  -0.05 -0.5
v  0.35 -0.05 -0.35

# Centre top/bottom
v  0.0  0.05  0.0
v  0.0 -0.05  0.0

# Normals
vn  0.0  1.0  0.0
vn  0.0 -1.0  0.0

# Top cap
f 17//1 1//1 2//1
f 17//1 2//1 3//1
